root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# C# source — this repo uses tabs (see CLAUDE.md)
[*.cs]
indent_style = tab
indent_size = 4

# Naming: PascalCase types/methods, camelCase locals, underscore-prefixed Harmony patch classes
dotnet_naming_rule.types_pascal.severity = suggestion
dotnet_naming_rule.types_pascal.symbols = type_symbols
dotnet_naming_rule.types_pascal.style = pascal_case_style
dotnet_naming_symbols.type_symbols.applicable_kinds = class, struct, interface, enum, method, property
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.locals_camel.severity = suggestion
dotnet_naming_rule.locals_camel.symbols = local_symbols
dotnet_naming_rule.locals_camel.style = camel_case_style
dotnet_naming_symbols.local_symbols.applicable_kinds = local, parameter
dotnet_naming_style.camel_case_style.capitalization = camel_case

# Common correctness analyzers — surfaced as warnings for fast feedback
dotnet_diagnostic.CA2200.severity = warning   # rethrow to preserve stack
dotnet_diagnostic.IDE0005.severity = suggestion # unnecessary usings
csharp_prefer_braces = true:suggestion

# XML defs/metadata
[*.xml]
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
